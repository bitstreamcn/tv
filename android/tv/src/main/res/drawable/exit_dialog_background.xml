<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 渐变背景 -->
    <gradient
        android:startColor="#E61A1A1A"
        android:endColor="#CC1A1A1A"
        android:angle="45" />
    
    <!-- 圆角 -->
    <corners android:radius="12dp" />
    
    <!-- 边框 -->
    <stroke
        android:width="1dp"
        android:color="#33FFFFFF" />
    
    <!-- 阴影效果 -->
    <padding
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp" />
</shape>